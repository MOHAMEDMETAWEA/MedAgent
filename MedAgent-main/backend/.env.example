# App
ENV=local
VERSION=0.1.0
COMMIT_SHA=local
SECRET_KEY=change-me-minimum-32-chars-long!!

# CORS (comma-separated list handled by pydantic)
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medagent

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
MAX_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=30
DISABLE_RATE_LIMIT=false

# Email (mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_ADDRESS=noreply@medagent.local
EMAILS_FROM_NAME=MedAgent

# Logging
LOG_LEVEL=INFO

# Notifications scheduler
NOTIFICATION_POLL_INTERVAL_SECONDS=60

# ── LLM / AI ────────────────────────────────────────────
# LLM — OpenRouter (https://openrouter.ai/keys)
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-...
LLM_MODEL=qwen/qwen-2.5-72b-instruct

# Optional cheaper / faster model for hallucination checker (OpenRouter free tier works)
VERIFIER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Vision analysis — defaults to same provider, override if you use a different vision endpoint
VISION_PROVIDER=openai_compat
VISION_MODEL=

# ── PHI Encryption ──────────────────────────────────────
# Set to true to encrypt sensitive patient fields at the application layer (Fernet AES-256)
PHI_ENCRYPTION_ENABLED=false
# 32-byte base64-encoded Fernet key. Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=

# ── Observability ───────────────────────────────────────
# Sentry error tracking (optional)
SENTRY_DSN=

# MLflow experiment tracking (optional, Phase 3)
MLFLOW_TRACKING_URI=
