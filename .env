# OpenAI API Configuration
OPENAI_API_KEY= 
EMBEDDING_MODEL=text-embedding-3-small

# Security & Governance
# Key for encrypting medical data (Generate with: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode()))
DATA_ENCRYPTION_KEY=your_encryption_key_here

# Admin Authentication
ADMIN_API_KEY=your_admin_api_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Google Calendar Configuration (Optional)
# Path to credentials.json (e.g. ./credentials.json)
# If using file path logic in code:
CALENDAR_CREDENTIALS_FILE=credentials.json

# API Configuration
MEDAGENT_API_URL=http://localhost:8000
LOG_LEVEL=INFO

# Feature Flags
ENABLE_SAFETY_CHECKS=True
ENABLE_AUDIO=False
